---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BannerCTA from '../components/BannerCTA.astro';
import { SITE_TITLE, CTA } from '../consts';
---

<html lang="en">
  <head>
    <BaseHead title={`About | ${SITE_TITLE}`} description="OriginX AI helps enterprises deploy AI voice agents and automation systems that cut costs and scale operations." />
  </head>
  <body>
    <Header />
    <main>
      <h1>About OriginX AI</h1>
      <p>
        OriginX AI helps enterprises deploy AI voice agents and automation systems that cut costs and scale operations. We focus on real results — not vanity metrics.
      </p>
      <p>
        Founded by <a href="https://www.linkedin.com/in/fahadrahman9/">Fahad Rahman</a>, we work with businesses that want to leverage AI to handle customer calls, automate lead workflows, and build systems that run without constant human intervention.
      </p>
      <h2>What We Do</h2>
      <ul>
        <li><strong>AI Voice Agents</strong> — Deploy AI that handles inbound and outbound calls at $0.04-$0.08/min vs $2.38/min for human agents</li>
        <li><strong>Lead Automation</strong> — Claim, qualify, and follow up with leads automatically across channels</li>
        <li><strong>CRM Integration</strong> — Connect AI agents to GoHighLevel, HubSpot, and custom CRMs</li>
        <li><strong>Custom AI Workflows</strong> — End-to-end automation using n8n, Make, and custom APIs</li>
      </ul>
      <h2>Why This Blog</h2>
      <p>
        We publish in-depth technical content because enterprise decision-makers deserve real data, not marketing fluff. Every article includes actual cost breakdowns, implementation details, and honest comparisons.
      </p>
      <BannerCTA />
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }
</style>
