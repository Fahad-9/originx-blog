---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { SITE_URL, CTA } from '../consts';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const faqs = [
  {
    q: 'What types of AI Voice Agents can you develop?',
    a: 'OriginX AI custom-develops a variety of AI voice agents: hospital appointment reminders, lead qualifiers, customer support agents, cold calling facilitators, and more. These are highly effective, personalized solutions — nearly any request can be achieved.',
  },
  {
    q: 'What are Operational AI Voice-Driven Agents?',
    a: 'Next-generation AI solutions that integrate with all of your software platforms to solve real business challenges. Our AI uses humanlike voices and tonality to accomplish key business tasks with precision.',
  },
  {
    q: 'Is the demo really free?',
    a: 'Yes — no hidden fees or obligations. Our goal is to let you experience the value before making any commitment.',
  },
  {
    q: 'Will the AI agent call my real customers?',
    a: 'During the demo, we use test scenarios so your real customers are never contacted without your approval. You control when to go live.',
  },
  {
    q: 'Can AI voice agents handle complex or sensitive calls?',
    a: 'Yes. Our agents are trained to handle nuanced conversations, follow compliance guidelines, and escalate to human agents when needed.',
  },
  {
    q: 'Will this AI replace my staff or just help them?',
    a: 'AI augments your team — it handles repetitive calls so your staff can focus on high-value work. Most clients see their team become more productive, not smaller.',
  },
  {
    q: 'Is my data safe?',
    a: 'Absolutely. We follow industry-standard security practices including encryption at rest and in transit. We can discuss specific compliance requirements for your industry.',
  },
  {
    q: 'How do I get started with OriginX AI?',
    a: 'Book a free discovery call. We\'ll assess your needs, show you a live demo, and provide a custom implementation plan — no obligation.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="OriginX AI — AI Voice Agents & Automation for Business"
      description="Stop missing revenue from unanswered calls. OriginX AI deploys AI voice agents that answer, qualify, and book appointments 24/7."
    />
    <SchemaOrg
      type="website"
      title="OriginX AI — AI Voice Agents & Automation for Business"
      description="AI voice agents and automation for enterprises that want real results."
      url={SITE_URL}
    />
  </head>
  <body>
    <Header />
    <main>
      <!-- ========== HERO ========== -->
      <section class="hero" data-animate>
          <h1 class="hero-heading">
            Replace Missed Calls With<br />AI Voice Agents
          </h1>
          <p class="hero-sub">
            Stop missing revenue from unanswered calls. Our AI Voice
            Receptionist instantly answers, qualifies, and books appointments.
          </p>
          <a href={CTA.url} class="btn-dark">Book Your Free AI Audit Call</a>
      </section>

      <!-- ========== DASHBOARD SHOWCASE ========== -->
      <section class="dashboard-showcase">
        <div class="dashboard-tabs">
          <span class="tab">Real-Time AI Calls</span>
          <span class="tab">AI Calls & Follow Ups</span>
          <span class="tab tab-active">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            AI Sales & Customer Service
          </span>
        </div>
        <div class="dashboard-frame">
          <div class="dashboard-bg">
            <img src="/images/hero-gradient.png" alt="" class="gradient-bg" loading="eager" data-no-dim />
          </div>
          <div class="dashboard-image">
            <img src="/images/dashboard-analytics.png" alt="OriginX AI Dashboard showing annual profit, traffic, and sales pipeline analytics" loading="eager" data-no-dim />
          </div>
        </div>
      </section>

      <!-- ========== PARTNERS (Infinite Scroll) ========== -->
      <section class="partners">
        <p class="partners-label">Built with world-class AI infrastructure</p>
        <div class="marquee-wrapper">
          <div class="marquee-track">
            <img src="/images/partner-logos-dark.png" alt="Partner logos" class="marquee-logos" />
            <img src="/images/partner-logos-dark.png" alt="" class="marquee-logos" aria-hidden="true" />
            <img src="/images/partner-logos-dark.png" alt="" class="marquee-logos" aria-hidden="true" />
            <img src="/images/partner-logos-dark.png" alt="" class="marquee-logos" aria-hidden="true" />
          </div>
        </div>
      </section>

      <!-- ========== SERVICES ========== -->
      <section class="services" id="features">
        <div class="container">
          <div class="section-header" data-animate>
            <span class="section-badge">AI Services</span>
            <h2>AI-Powered Solutions for Every Business Need</h2>
            <p>Enterprise-grade AI voice agents and automation — built for your specific business needs.</p>
          </div>
          <div class="services-grid" data-animate>
            <!-- Inbound AI Receptionist -->
            <div class="service-card service-card-warm">
              <div class="service-card-content">
                <h3>Inbound AI Receptionist</h3>
                <p>Never miss a call again. AI answers instantly 24/7, qualifies leads, books appointments, and sends you real-time summaries.</p>
                <ul class="service-features">
                  <li>24/7 instant call answering</li>
                  <li>Lead qualification & scoring</li>
                  <li>Appointment booking</li>
                  <li>Real-time CRM sync</li>
                </ul>
                <a href={CTA.url} class="btn-dark btn-sm">Get Started</a>
              </div>
              <div class="service-card-visual">
                <img src="/images/chat-widget.png" alt="AI chat interface" data-no-dim />
              </div>
            </div>

            <!-- Outbound AI Sales -->
            <div class="service-card service-card-coral">
              <div class="service-card-content">
                <h3>Outbound AI Sales</h3>
                <p>AI makes thousands of calls for lead reactivation, appointment reminders, and follow-ups — at a fraction of the cost.</p>
                <ul class="service-features">
                  <li>Automated outbound campaigns</li>
                  <li>Lead reactivation</li>
                  <li>Follow-up sequences</li>
                  <li>Performance analytics</li>
                </ul>
                <a href={CTA.url} class="btn-dark btn-sm">Get Started</a>
              </div>
              <div class="service-card-visual">
                <img src="/images/robot.png" alt="AI sales agent" data-no-dim />
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ========== FEATURE: SMARTER CONVERSATIONS ========== -->
      <section class="feature-section">
        <div class="container">
          <div class="feature-row" data-animate>
            <div class="feature-text">
              <span class="section-badge">Intelligent AI</span>
              <h2>Smarter Conversations, Powered by AI</h2>
              <p>Our AI agents don't just answer calls — they understand context, remember preferences, and adapt to each conversation in real time.</p>
              <ul class="feature-list">
                <li>
                  <strong>Natural Language Understanding</strong>
                  <span>Handles complex queries, accents, and interruptions with human-like comprehension</span>
                </li>
                <li>
                  <strong>Context-Aware Responses</strong>
                  <span>Remembers conversation history and adapts responses based on caller data</span>
                </li>
                <li>
                  <strong>Seamless Handoffs</strong>
                  <span>Transfers to human agents when needed, with full context and transcripts</span>
                </li>
              </ul>
            </div>
            <div class="feature-visual">
              <img src="/images/dashboard-chat.png" alt="AI dashboard with prompt interface, sales analyzing, and calendar integration" loading="lazy" data-no-dim />
            </div>
          </div>
        </div>
      </section>

      <!-- ========== FEATURE: DATA-DRIVEN ========== -->
      <section class="feature-section feature-reversed">
        <div class="container">
          <div class="feature-row" data-animate>
            <div class="feature-text">
              <span class="section-badge">Analytics</span>
              <h2>Data-Driven Performance at Scale</h2>
              <p>Track every call, measure every outcome, and optimize your AI agents with real-time analytics dashboards.</p>
              <ul class="feature-list">
                <li>
                  <strong>AI Lead Scoring</strong>
                  <span>Automatically score and prioritize leads based on conversation signals</span>
                </li>
                <li>
                  <strong>Sales Funnel Optimization</strong>
                  <span>Visualize your pipeline from first contact to closed deal</span>
                </li>
                <li>
                  <strong>Team Productivity Tracking</strong>
                  <span>Monitor AI and human agent performance in one unified dashboard</span>
                </li>
              </ul>
            </div>
            <div class="feature-visual">
              <img src="/images/dashboard-lead-scoring.png" alt="AI lead scoring dashboard with 72% gauge, sales funnel, and performance tracking" loading="lazy" data-no-dim />
            </div>
          </div>
        </div>
      </section>

      <!-- ========== PROCESS ========== -->
      <section class="process">
        <div class="container">
          <div class="section-header" data-animate>
            <span class="section-badge">How It Works</span>
            <h2>From Discovery to Deployment</h2>
            <p>We handle everything — you just show up to a call.</p>
          </div>
          <div class="process-grid" data-animate>
            <div class="process-step">
              <div class="step-num">01</div>
              <h3>Discovery Call</h3>
              <p>We learn your business, call flows, and goals.</p>
            </div>
            <div class="process-step">
              <div class="step-num">02</div>
              <h3>Custom AI Build</h3>
              <p>We design and train voice agents tailored to your exact needs.</p>
            </div>
            <div class="process-step">
              <div class="step-num">03</div>
              <h3>Integration</h3>
              <p>Connect to your CRM, calendar, and phone system — seamlessly.</p>
            </div>
            <div class="process-step">
              <div class="step-num">04</div>
              <h3>Launch & Optimize</h3>
              <p>Go live, monitor performance, and continuously improve.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ========== REVIEWS ========== -->
      <section class="reviews" id="reviews">
        <div class="container">
          <div class="section-header" data-animate>
            <span class="section-badge">Reviews</span>
            <h2>Satisfied Clients Worldwide</h2>
            <p>See what business leaders say about working with OriginX AI.</p>
          </div>
          <div class="reviews-grid" data-animate>
            <div class="review-card">
              <div class="review-company">Veltrix</div>
              <p>"Trilo completely transformed how we manage our sales pipeline. We've closed 40% more deals in just three months."</p>
              <div class="review-author">
                <strong>Robert Fox</strong>
                <span>CEO & Founder</span>
              </div>
            </div>
            <div class="review-card">
              <div class="review-company">Trivexa</div>
              <p>"Our team productivity jumped by 35% after adopting Trilo. It's like upgrading your team with AI superpowers solutions."</p>
              <div class="review-author">
                <strong>Esther Howard</strong>
                <span>CEO & Founder</span>
              </div>
            </div>
            <div class="review-card">
              <div class="review-company">Brillora</div>
              <p>"Since switching to Trilo, our sales forecasting has become almost perfectly accurate. No more guesswork."</p>
              <div class="review-author">
                <strong>Guy Hawkins</strong>
                <span>CEO & Founder</span>
              </div>
            </div>
            <div class="review-card">
              <div class="review-company">Revomia</div>
              <p>"Trilo transformed how we manage our sales pipeline — it's fast, smart, and actually enjoyable to use. We've used a dozen CRMs."</p>
              <div class="review-author">
                <strong>Albert Flores</strong>
                <span>CEO & Founder</span>
              </div>
            </div>
            <div class="review-card">
              <div class="review-company">Fluxenta</div>
              <p>"Trilo doesn't just help us track deals. It helps us close them — faster and more efficiently. Our sales team finally has one tool that does it all."</p>
              <div class="review-author">
                <strong>Floyd Miles</strong>
                <span>CEO & Founder</span>
              </div>
            </div>
            <div class="review-card">
              <div class="review-company">Zentryx</div>
              <p>"Since switching to Trilo, we've boosted our conversion rate by 35% and saved over 15 hours per week. Trilo helped us cut our lead response."</p>
              <div class="review-author">
                <strong>Arlene McCoy</strong>
                <span>CEO & Founder</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ========== RECENT BLOG POSTS ========== -->
      {recentPosts.length > 0 && (
        <section class="recent-posts">
          <div class="container">
            <div class="section-header">
              <span class="section-badge">Blog</span>
              <h2>Latest from the Blog</h2>
              <p>In-depth guides with real data, not marketing fluff.</p>
            </div>
            <div class="posts-grid">
              {recentPosts.map((post) => (
                <a href={`/blog/${post.id}/`} class="post-card">
                  <span class="post-category">{post.data.categories?.[0]}</span>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                  <span class="post-read">Read article &rarr;</span>
                </a>
              ))}
            </div>
            <div class="posts-more">
              <a href="/blog" class="btn-outline">View All Posts</a>
            </div>
          </div>
        </section>
      )}

      <!-- ========== FAQ ========== -->
      <section class="faq" id="faq">
        <div class="container">
          <div class="faq-card">
            <div class="faq-header">
              <span class="section-badge">FAQ</span>
              <h2>Frequently Asked Questions</h2>
            </div>
            <div class="faq-list">
              {faqs.map((faq, i) => (
                <details class="faq-item" open={i === 0}>
                  <summary>{faq.q}</summary>
                  <p>{faq.a}</p>
                </details>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- ========== FINAL CTA ========== -->
      <section class="final-cta">
        <div class="cta-bg">
          <img src="/images/hero-gradient.png" alt="" class="cta-gradient" data-no-dim />
        </div>
        <div class="cta-content">
          <h2>Ready to Transform Your Business?</h2>
          <p>Book a free AI audit call and see exactly how AI voice agents can increase your revenue and save hours every week.</p>
          <a href={CTA.url} class="btn-dark btn-lg">Book Your Free AI Audit Call</a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  /* ==================== LAYOUT ==================== */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .section-header h2 {
    margin-top: 0.5rem;
    margin-bottom: 0.75rem;
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .section-header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 540px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .section-badge {
    display: inline-block;
    padding: 0.3rem 0.9rem;
    border-radius: 9999px;
    background: #FFF1ED;
    color: #E8501A;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }
  :global(.dark) .section-badge {
    background: rgba(232, 80, 26, 0.15);
  }

  /* ==================== BUTTONS ==================== */
  .btn-dark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 2rem;
    border-radius: 50px;
    background: #111;
    color: #fff !important;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: transform 150ms ease, box-shadow 150ms ease;
    border: none;
    cursor: pointer;
  }
  .btn-dark:visited { color: #fff !important; }
  .btn-dark:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
  }
  .btn-dark.btn-sm {
    padding: 0.65rem 1.5rem;
    font-size: 0.9rem;
  }
  .btn-dark.btn-lg {
    padding: 1rem 2.5rem;
    font-size: 1.05rem;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    border-radius: 50px;
    border: 2px solid var(--border);
    background: transparent;
    color: var(--text-primary) !important;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: border-color 150ms ease, background-color 150ms ease;
  }
  .btn-outline:visited { color: var(--text-primary) !important; }
  .btn-outline:hover {
    border-color: #E8501A;
    background: rgba(232, 80, 26, 0.04);
  }

  /* ==================== HERO ==================== */
  .hero {
    padding: 5rem 1.5rem 3rem;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }
  .hero-heading {
    font-size: clamp(2.5rem, 5vw + 1rem, 4.5rem);
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 1.5rem;
    background: linear-gradient(180deg, #C4C4C4 0%, #999 30%, #333 65%, #111 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  :global(.dark) .hero-heading {
    background: linear-gradient(180deg, #555 0%, #888 30%, #ccc 65%, #E2E8F0 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }
  .hero-sub {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 560px;
    margin: 0 auto 2rem;
  }

  /* ==================== DASHBOARD SHOWCASE ==================== */
  .dashboard-showcase {
    position: relative;
    padding: 0 1.5rem 4rem;
    margin-top: 1rem;
  }
  .dashboard-tabs {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
  }
  .dashboard-frame {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 0;
  }
  .dashboard-bg {
    position: absolute;
    top: 15%;
    left: 50%;
    transform: translateX(-50%);
    width: 140%;
    max-width: 2000px;
    height: 70%;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.8s ease-out;
    overflow: hidden;
    border-radius: 32px;
  }
  .dashboard-bg.visible {
    opacity: 1;
  }
  .gradient-bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    filter: none;
  }
  :global(.dark) .gradient-bg {
    opacity: 0.4;
  }
  .tab {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.6rem 1.25rem;
    border-radius: 50px;
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(8px);
    font-size: 0.85rem;
    font-weight: 500;
    color: #666;
    border: 1px solid rgba(0,0,0,0.06);
  }
  .tab-active {
    background: #fff;
    color: #111;
    font-weight: 600;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }
  .tab-active svg {
    color: #E8501A;
  }
  :global(.dark) .tab {
    background: rgba(30,41,59,0.7);
    color: #94A3B8;
    border-color: rgba(255,255,255,0.06);
  }
  :global(.dark) .tab-active {
    background: #1E293B;
    color: #E2E8F0;
  }
  .dashboard-image {
    position: relative;
    z-index: 1;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15), 0 4px 16px rgba(0,0,0,0.08);
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    max-width: 960px;
    margin: 0 auto;
  }
  :global(.dark) .dashboard-image {
    background: #1E293B;
    border-color: rgba(255,255,255,0.06);
  }
  .dashboard-image img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0;
  }

  /* ==================== PARTNERS (Marquee) ==================== */
  .partners {
    padding: 3rem 0 4rem;
    text-align: center;
    overflow: hidden;
  }
  .partners-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    margin: 0 0 2rem;
  }
  .marquee-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  }
  .marquee-track {
    display: flex;
    align-items: center;
    gap: 5rem;
    width: max-content;
    animation: marquee 40s linear infinite;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-25%); }
  }
  .marquee-wrapper:hover .marquee-track {
    animation-play-state: paused;
  }
  .marquee-logos {
    height: 36px;
    width: auto;
    flex-shrink: 0;
    opacity: 0.75;
  }
  :global(.dark) .marquee-logos {
    filter: invert(1) brightness(2);
  }

  /* ==================== SERVICES ==================== */
  .services {
    padding: 5rem 0;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .service-card {
    border-radius: 20px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    overflow: hidden;
    position: relative;
    min-height: 420px;
  }
  .service-card-warm {
    background: linear-gradient(135deg, #FFF5F0 0%, #FFE8DB 50%, #FFDBC8 100%);
    border: 1px solid rgba(232, 80, 26, 0.08);
  }
  :global(.dark) .service-card-warm {
    background: linear-gradient(135deg, rgba(232, 80, 26, 0.12) 0%, rgba(232, 80, 26, 0.06) 100%);
    border-color: rgba(232, 80, 26, 0.15);
  }
  .service-card-coral {
    background: linear-gradient(135deg, #FFF0ED 0%, #FFE0D6 50%, #FFD1C2 100%);
    border: 1px solid rgba(232, 80, 26, 0.08);
  }
  :global(.dark) .service-card-coral {
    background: linear-gradient(135deg, rgba(232, 80, 26, 0.1) 0%, rgba(200, 60, 20, 0.06) 100%);
    border-color: rgba(232, 80, 26, 0.15);
  }
  .service-card-content {
    position: relative;
    z-index: 1;
  }
  .service-card-content h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
    letter-spacing: -0.01em;
  }
  .service-card-content p {
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0 0 1.25rem;
    font-size: 0.95rem;
  }
  .service-features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }
  .service-features li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0;
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin: 0;
  }
  .service-features li::before {
