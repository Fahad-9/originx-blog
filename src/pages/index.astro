---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { SITE_URL, CTA } from '../consts';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const faqs = [
  {
    q: 'What types of AI Voice Agents can you develop?',
    a: 'OriginX AI custom-develops a variety of AI voice agents: hospital appointment reminders, lead qualifiers, customer support agents, cold calling facilitators, and more. These are highly effective, personalized solutions — nearly any request can be achieved.',
  },
  {
    q: 'What are Operational AI Voice-Driven Agents?',
    a: 'Next-generation AI solutions that integrate with all of your software platforms to solve real business challenges. Our AI uses humanlike voices and tonality to accomplish key business tasks with precision.',
  },
  {
    q: 'Is the demo really free?',
    a: 'Yes — no hidden fees or obligations. Our goal is to let you experience the value before making any commitment.',
  },
  {
    q: 'Will the AI agent call my real customers?',
    a: 'During the demo, we use test scenarios so your real customers are never contacted without your approval. You control when to go live.',
  },
  {
    q: 'Can AI voice agents handle complex or sensitive calls?',
    a: 'Yes. Our agents are trained to handle nuanced conversations, follow compliance guidelines, and escalate to human agents when needed.',
  },
  {
    q: 'Will this AI replace my staff or just help them?',
    a: 'AI augments your team — it handles repetitive calls so your staff can focus on high-value work. Most clients see their team become more productive, not smaller.',
  },
  {
    q: 'Is my data safe?',
    a: 'Absolutely. We follow industry-standard security practices including encryption at rest and in transit. We can discuss specific compliance requirements for your industry.',
  },
  {
    q: 'How do I get started with OriginX AI?',
    a: 'Book a free discovery call. We\'ll assess your needs, show you a live demo, and provide a custom implementation plan — no obligation.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="OriginX AI — AI Voice Agents & Automation for Business"
      description="Stop missing revenue from unanswered calls. OriginX AI deploys AI voice agents that answer, qualify, and book appointments 24/7."
    />
    <SchemaOrg
      type="website"
      title="OriginX AI — AI Voice Agents & Automation for Business"
      description="AI voice agents and automation for enterprises that want real results."
      url={SITE_URL}
    />
